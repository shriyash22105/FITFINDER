sequenceDiagram
    participant U as User
    participant F as Frontend
    participant B as Backend
    participant D as DB
    U->>F: POST /api/auth/login
    F->>B: POST /login {userid, password}
    B->>D: SELECT user WHERE userid
    D-->>B: user data
    B->>B: bcrypt.checkpw()
    B->>B: generate JWT token
    B-->>F: {token, userId}
    F->>localStorage: store token
    F-->>U: Redirect dashboard
